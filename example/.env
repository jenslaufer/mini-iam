# Launch Kit (IAM)
PORT=8080
ISSUER_URL=http://localhost:4000/auth
CORS_ORIGINS=*
ADMIN_EMAIL=admin@launch-kit.local
ADMIN_PASSWORD=changeme
DEFAULT_TENANT=default
EXTERNAL_PORT=3000

# Demo App
DEMO_PORT=4000

# OIDC — public issuer (must match `iss` claim in tokens)
OIDC_ISSUER_URL=http://localhost:4000/auth

# OIDC — internal JWKS endpoint (docker-internal, bypasses nginx)
OIDC_JWKS_URI=http://launch-kit:8080/jwks

# OIDC — optional audience validation
OIDC_AUDIENCE=

# Frontend — browser-relative URLs (proxied by nginx)
VITE_OIDC_ISSUER_URL=/auth
VITE_API_URL=/api
