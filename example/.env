# Launch Kit (IAM)
PORT=8080
IAM_PORT=8080
ISSUER_URL=http://localhost:8080
CORS_ORIGINS=*
ADMIN_EMAIL=admin@launch-kit.local
ADMIN_PASSWORD=changeme
DEFAULT_TENANT=default
EXTERNAL_PORT=3001

# Demo App
DEMO_PORT=4000

# OIDC — public issuer (must match `iss` claim in tokens)
OIDC_ISSUER_URL=http://localhost:8080/t/demo

# OIDC — internal JWKS (docker-internal)
OIDC_JWKS_URI=http://launch-kit:8080/t/demo/jwks

# OIDC — optional audience validation
OIDC_AUDIENCE=

# Frontend — full URL to IAM (no nginx proxy)
VITE_OIDC_ISSUER_URL=http://localhost:8080/t/demo
VITE_API_URL=/api
