# =============================================================================
# Launch Kit — Environment Variables
# =============================================================================
# Copy this file: cp .env.example .env
# Then edit values for your environment.

# --- Server ---
PORT=8080                          # Backend HTTP port
ISSUER_URL=http://localhost:3000   # Token issuer / base URL (must match public URL)
CORS_ORIGINS=http://localhost:3000 # Comma-separated allowed origins (empty = reject all)
DATABASE_PATH=/data/launch-kit.db  # SQLite database path
EXTERNAL_PORT=3000                 # Host port for the frontend (Nginx)

# --- Auth (seed admin on first start) ---
ADMIN_EMAIL=admin@launch-kit.local # Platform admin email
ADMIN_PASSWORD=changeme            # Platform admin password (change this!)
DEFAULT_TENANT=default             # Default tenant slug (auto-created)
DEFAULT_TENANT_REGISTRATION=       # Set to any value to enable public registration on default tenant
KEY_ENCRYPTION_KEY=                # 32 bytes base64-encoded AES-256 key for encrypting RSA keys at rest

# --- SMTP (leave SMTP_HOST empty to log emails instead of sending) ---
SMTP_HOST=                         # SMTP server hostname
SMTP_PORT=587                      # SMTP port (587 = STARTTLS, 465 = SSL)
SMTP_USER=                         # SMTP username
SMTP_PASSWORD=                     # SMTP password
SMTP_FROM=                         # Default sender email address
SMTP_FROM_NAME=launch-kit          # Default sender display name
SMTP_RATE_MS=100                   # Delay between emails in milliseconds

# --- Import (optional) ---
TENANT_CONFIG=                     # Path to JSON file for auto-import on startup
